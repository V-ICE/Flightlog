# ============================================================
# Flightlog — Synology Environment Variables
# Place this file at: /volume1/docker/flightlog/.env
# Edit all values before running docker-compose up -d
# ============================================================

# ── Database ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ChangeThisRootPassword
MYSQL_DATABASE=uavlogbook
MYSQL_USER=uavlogbook_user
MYSQL_PASSWORD=ChangeThisAppPassword

# ── JWT Secret — generate with: openssl rand -hex 32 ─────
JWT_SECRET=changethisto64randomcharsminimumgeneratedwithopenssl

# ── AI import (optional, leave blank to disable) ──────────
ANTHROPIC_API_KEY=

# ── CORS — your NAS IP ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8080,http://192.168.0.2:8080

# ── App port (NAS host port) ──────────────────────────────
APP_PORT=8080

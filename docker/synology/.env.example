# ============================================================
# UAVLogBook — Synology DS412+ Environment Variables
# Place this file at: /volume1/docker/uavlogbook/.env
# Edit all values before running docker-compose up -d
# ============================================================

# ── Database ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ChangeThisRootPassword
MYSQL_DATABASE=uavlogbook
MYSQL_USER=uavlogbook_user
MYSQL_PASSWORD=ChangeThisAppPassword

# ── JWT Secret — generate with: openssl rand -hex 32 ─────
JWT_SECRET=changethisto64randomcharsminimumgeneratedwithopenssl

# ── AI import (optional, leave blank to disable) ──────────
ANTHROPIC_API_KEY=

# ── CORS — your NAS IP or domain ─────────────────────────
# Use your NAS IP address, e.g. http://192.168.1.50:8080
ALLOWED_ORIGINS=http://localhost:8080,http://192.168.1.50:8080

# ── App port (NAS host port) ──────────────────────────────
APP_PORT=8080

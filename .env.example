# ============================================================
# UAVLogBook — Environment Variables
# Copy to .env and fill in real values before running Docker.
#
#   cp .env.example .env
#   nano .env          # or use your preferred editor
#   docker compose up -d
#
# NEVER commit .env to git. It contains secrets.
# ============================================================

# ── Database ──────────────────────────────────────────────
# MySQL root password (used internally by MySQL container)
MYSQL_ROOT_PASSWORD=change_this_root_password_now

# Database name (auto-created by MySQL container)
MYSQL_DATABASE=uavlogbook

# App database user (use a restricted user, not root)
MYSQL_USER=uavlogbook_user
MYSQL_PASSWORD=change_this_db_password_now

# ── JWT Authentication ─────────────────────────────────────
# Must be at least 32 random characters. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change_this_to_64_random_chars_minimum_for_security_please

# ── AI-powered import (optional) ──────────────────────────
# Get your key at: https://console.anthropic.com/
# Leave blank to disable AI format detection (heuristics still work)
ANTHROPIC_API_KEY=

# ── Web app API URL ────────────────────────────────────────
# Used by Vite when building the React app.
# In Docker: leave as /api/v1 (Nginx/Apache proxy handles routing)
VITE_API_URL=/api/v1

# ── CORS allowed origins ───────────────────────────────────
# Comma-separated list of allowed browser origins
# For production: set to your actual domain(s)
# For local dev: http://localhost,http://localhost:3000
ALLOWED_ORIGINS=http://localhost,http://localhost:8080,https://yourdomain.com

# ── Nginx (production profile only) ───────────────────────
# Your domain name for SSL certificate and server_name directive
NGINX_SERVER_NAME=yourdomain.com

# ── PHP runtime tuning ────────────────────────────────────
# Large video files need high limits
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=8192M
PHP_POST_MAX_SIZE=8192M
PHP_MAX_EXECUTION_TIME=600

# ── App port (dev: access app directly without Nginx) ─────
# The app container binds to this port on your host
APP_PORT=8080

# ── Development only ──────────────────────────────────────
# Uncomment in dev to show PHP errors in browser
# PHP_DISPLAY_ERRORS=On
# PHP_ERROR_REPORTING=E_ALL
# OPCACHE_VALIDATE_TIMESTAMPS=1

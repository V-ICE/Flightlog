Options -Indexes
RewriteEngine On

# Route all /api/v1/* requests to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/v1/(.*)$ api/index.php [QSA,L]

# Security headers
Header always set X-Frame-Options DENY
Header always set X-XSS-Protection "1; mode=block"
Header always set X-Content-Type-Options nosniff
Header always set Referrer-Policy strict-origin-when-cross-origin
Header always set Permissions-Policy "geolocation=(self)"

# Enable Accept-Ranges for HTML5 video streaming (essential for seeking)
Header always set Accept-Ranges bytes

# Allow CORS for video files (needed for cross-origin video element)
<FilesMatch "\.(mp4|mov|avi|mkv|webm|mpg|3gp)$">
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    Header always set Access-Control-Allow-Headers "Range"
    Header always set Access-Control-Expose-Headers "Content-Length, Content-Range"
</FilesMatch>

# Block access to sensitive files
<FilesMatch "\.(php|sql|log|env)$">
    Order allow,deny
    Deny from all
</FilesMatch>
<Files "index.php">
    Allow from all
</Files>

# Protect uploads/logs directory from direct PHP execution
<Directory "uploads/logs">
    Options -ExecCGI
    php_flag engine off
    AddType text/plain .php .php5 .phtml
</Directory>

# Videos directory: allow direct access for browser video element
<Directory "uploads/videos">
    Options -ExecCGI
    php_flag engine off
    # DO NOT block mp4/mov/etc — browser needs direct access for HTML5 video
    AllowOverride None
    Require all granted
</Directory>

# SPA fallback for React web app
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/uploads/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
